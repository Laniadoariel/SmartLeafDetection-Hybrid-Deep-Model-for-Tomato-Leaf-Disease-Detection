# SmartLeafDetection Environment Variables

# Database (SQLite by default, switch to MySQL for production)
DATABASE_URL=sqlite:///./smartleaf.db
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/smartleaf

# JWT Secret (change in production!)
SECRET_KEY=smartleaf-dev-secret-change-in-prod

# File storage
UPLOAD_DIR=uploads
OUTPUT_DIR=processing_output
